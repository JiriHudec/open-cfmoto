<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- Branded header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="OpenCfMoto"
            android:src="@drawable/ic_ride"
            android:tint="@color/brand_orange" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="OpenCfMoto"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.01" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <!-- Hero status card: the one thing a rider glances at. -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.OpenCfMoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/status_icon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_status_circle"
                    android:contentDescription="Connection status"
                    android:padding="15dp"
                    android:src="@drawable/ic_ride"
                    android:tint="@color/status_idle" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/status_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ready"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/bike_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="No bike paired yet"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <ProgressBar
                        android:id="@+id/status_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:indeterminate="true"
                        android:indeterminateTint="@color/brand_orange"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Primary action: one tap. Reconnects to the last bike, or starts the scan flow. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_connect"
            style="@style/Widget.OpenCfMoto.Button.Connect"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_marginTop="16dp"
            android:text="Connect" />

        <!-- Primary controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_aa_start"
                style="@style/Widget.OpenCfMoto.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:text="Scan bike" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mirror_start"
                style="@style/Widget.OpenCfMoto.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:layout_weight="1"
                android:text="Mirror" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_aa_stop"
                style="@style/Widget.OpenCfMoto.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:text="Stop" />
        </LinearLayout>

        <!-- Secondary controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_setup"
                style="@style/Widget.OpenCfMoto.Button.Text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Setup" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_devices"
                style="@style/Widget.OpenCfMoto.Button.Text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Garage" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_trip"
                style="@style/Widget.OpenCfMoto.Button.Text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Trip" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_toggle_log"
                style="@style/Widget.OpenCfMoto.Button.Text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Logs" />
        </LinearLayout>

        <!-- Quick "type a destination → route shows on the dash" (no dash interaction needed). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/et_destination"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Navigate to… (type a destination)"
                android:imeOptions="actionGo"
                android:inputType="textPostalAddress"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_navigate"
                style="@style/Widget.OpenCfMoto.Segment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Go" />
        </LinearLayout>

        <!-- View + control the dash from inside the app (in-app mirror of the AA video). -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_hud_view"
            style="@style/Widget.OpenCfMoto.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="View &amp; control dash" />

        <!-- On-screen D-pad / knob + navigate box + handlebar-button mapping. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_controls"
            style="@style/Widget.OpenCfMoto.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Controls &amp; handlebar buttons" />

        <!-- Tips panel: fills the space and earns it (battery/how-to guidance). -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tips_panel"
            style="@style/Card.OpenCfMoto"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rider tips"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true"
                    android:textSize="12sp"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="• Keep the phone on the bike's USB charger — the live video runs warm.\n• Press the phone's power button to turn its screen OFF while riding; projection keeps running and saves battery.\n• Handlebar media/call buttons work once the phone is paired to the bike over Bluetooth.\n• In Setup you can tune battery (fps), screen fit, and try the sharper HD resolution."
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Collapsible diagnostics: hidden by default so the home screen is just Connect. -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/log_panel"
            style="@style/Card.OpenCfMoto.Log"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Diagnostics"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_share_log"
                        style="@style/Widget.OpenCfMoto.Button.Text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:text="Share" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear"
                        style="@style/Widget.OpenCfMoto.Button.Text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:text="Clear" />
                </LinearLayout>

                <ScrollView
                    android:id="@+id/log_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="4dp"
                    android:background="@color/bg"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/log_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:contentDescription="Logs"
                        android:fontFamily="monospace"
                        android:textColor="#9CDCFE"
                        android:textIsSelectable="true"
                        android:textSize="11sp" />
                </ScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</LinearLayout>
