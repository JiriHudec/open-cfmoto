<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/hud_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <SurfaceView
        android:id="@+id/hud_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Shown when Android Auto isn't live yet -->
    <TextView
        android:id="@+id/hud_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:padding="24dp"
        android:text="Start Android Auto and connect to your bike to see the dash here."
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Top bar: close + title + controls toggle -->
    <LinearLayout
        android:id="@+id/hud_topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#66000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <Button
            android:id="@+id/hud_close"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="44dp"
            android:text="✕"
            android:textSize="18sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Dash view"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/hud_toggle_controls"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Controls" />

        <Button
            android:id="@+id/hud_fullscreen"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="44dp"
            android:layout_marginStart="4dp"
            android:text="⛶"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Bottom control bar (works on every dash via the AAP INPUT channel) -->
    <HorizontalScrollView
        android:id="@+id/hud_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#66000000"
        android:paddingHorizontal="6dp"
        android:paddingVertical="6dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:divider="@null">

            <Button android:id="@+id/hud_knob_back" android:layout_width="wrap_content" android:layout_height="48dp" android:minWidth="52dp" android:text="⟲" android:textSize="18sp" />
            <Button android:id="@+id/hud_left" android:layout_width="wrap_content" android:layout_height="48dp" android:minWidth="52dp" android:text="◀" />
            <Button android:id="@+id/hud_up" android:layout_width="wrap_content" android:layout_height="48dp" android:minWidth="52dp" android:text="▲" />
            <Button android:id="@+id/hud_ok" android:layout_width="wrap_content" android:layout_height="48dp" android:minWidth="60dp" android:text="OK" />
            <Button android:id="@+id/hud_down" android:layout_width="wrap_content" android:layout_height="48dp" android:minWidth="52dp" android:text="▼" />
            <Button android:id="@+id/hud_right" android:layout_width="wrap_content" android:layout_height="48dp" android:minWidth="52dp" android:text="▶" />
            <Button android:id="@+id/hud_knob_fwd" android:layout_width="wrap_content" android:layout_height="48dp" android:minWidth="52dp" android:text="⟳" android:textSize="18sp" />
            <Button android:id="@+id/hud_back" android:layout_width="wrap_content" android:layout_height="48dp" android:minWidth="64dp" android:text="Back" />
            <Button android:id="@+id/hud_home" android:layout_width="wrap_content" android:layout_height="48dp" android:minWidth="64dp" android:text="Home" />
            <Button android:id="@+id/hud_voice" android:layout_width="wrap_content" android:layout_height="48dp" android:minWidth="64dp" android:text="🎙" android:textSize="16sp" />
        </LinearLayout>
    </HorizontalScrollView>
</FrameLayout>
