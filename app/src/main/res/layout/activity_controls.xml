<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/controls_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Controls"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:text="Drive Android Auto without touching the dash: type a destination, use the on-screen pad, or map the bike's handlebar buttons."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- ===== Navigate to… ===== -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.OpenCfMoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Navigate to…"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true"
                    android:textSize="12sp"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Type an address or place; the route appears on the dash. Enter it while parked."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/et_nav"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Destination"
                    android:inputType="textPostalAddress"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_nav_go"
                    style="@style/Widget.OpenCfMoto.Segment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Navigate" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Map theme ===== -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.OpenCfMoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Map theme"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true"
                    android:textSize="12sp"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/theme_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Auto switches the dash map to dark at night and light by day. Applies instantly while projecting."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theme_auto"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:text="Auto" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theme_day"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:layout_weight="1"
                        android:text="Day" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theme_night"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:text="Night" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== On-screen pad ===== -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.OpenCfMoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="On-screen pad"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true"
                    android:textSize="12sp"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="The rotary knob steps through lists; the arrows jump between areas. Works only while Android Auto is projecting."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <!-- knob back / up / knob fwd -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_knob_back"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⟲ Prev" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_dpad_up"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="▲" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_knob_fwd"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Next ⟳" />
                </LinearLayout>

                <!-- left / OK / right -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_dpad_left"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="◀" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_select"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="OK" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_dpad_right"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="▶" />
                </LinearLayout>

                <!-- down -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_dpad_down"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="▼" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />
                </LinearLayout>

                <!-- back / home / assistant -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_back"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Back" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_home"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Home" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_assistant"
                        style="@style/Widget.OpenCfMoto.Segment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Voice" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Handlebar buttons ===== -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card.OpenCfMoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Handlebar buttons"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true"
                    android:textSize="12sp"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tv_touch_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:padding="10dp"
                    android:background="@drawable/hint_pill"
                    android:text="Your dash is a touchscreen — just tap the screen to navigate. Handlebar-button control is meant for non-touch dashes (e.g. 450SR); on this bike it can't move the menu and only pauses your music."
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_control_aa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Handlebar buttons drive Android Auto"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Requires the phone paired to the bike over Bluetooth. While on, the buttons navigate Android Auto instead of skipping music tracks."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_customize"
                    style="@style/Widget.OpenCfMoto.Segment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Customize buttons" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
